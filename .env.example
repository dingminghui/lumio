# PostgreSQL（生产环境请用 Neon / Supabase / Vercel Postgres 等托管库）
# Serverless 建议带连接池，例如 Neon 的 pooled URL
DATABASE_URL=postgres://user:password@host:5432/lumio?sslmode=require

# 加密保存在「个人资料」里的模型 API Key（随机长字符串，部署后勿改）
MODEL_CONFIG_SECRET=replace-with-a-long-random-secret

# 可选：DeepSeek 默认端点与模型
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
